# =============================================================================
# SyncSpace Client — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running locally.
# NEVER commit your actual .env file to version control.
# =============================================================================

# --- Backend API URL ---
# The base URL of the SyncSpace backend REST API (no trailing slash).
# Local development: http://localhost:5005/api/v1
# Production (Render): https://syncspace-backend-44cl.onrender.com/api/v1
VITE_API_URL=http://localhost:5005/api/v1

# --- Backend Socket.IO URL ---
# The URL of the SyncSpace backend for real-time Socket.IO connection.
# This should be just the base URL (no /api/v1 suffix).
# Local development: http://localhost:5005
# Production (Render): https://syncspace-backend-44cl.onrender.com
VITE_SOCKET_URL=http://localhost:5005
